# Copy this to .env.production.local and fill in your Railway domain.
# These vars must also be added to Vercel project → Settings → Environment Variables.
#
# Run `docker/utils/generate-keys.sh` to get ANON_KEY / SERVICE_ROLE_KEY values,
# then copy them from your Railway variables tab.

# ---- Railway backend URL (Kong gateway public domain) ----
SUPABASE_URL=https://<your-railway-domain>
SUPABASE_PUBLIC_URL=https://<your-railway-domain>
NEXT_PUBLIC_GOTRUE_URL=https://<your-railway-domain>/auth/v1

# ---- Keys (must match what Railway has in its Variables tab) ----
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_KEY=<service-role-key>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_SUPABASE_URL=https://<your-railway-domain>

# ---- Postgres meta URL (via Kong) ----
STUDIO_PG_META_URL=https://<your-railway-domain>/pg

# ---- Studio defaults ----
DEFAULT_ORGANIZATION_NAME=Default Organization
DEFAULT_PROJECT_NAME=Default Project
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-me

# ---- Analytics (Logflare via Railway) ----
LOGFLARE_URL=https://<your-railway-domain>/analytics
LOGFLARE_PRIVATE_ACCESS_TOKEN=<logflare-private-token>
NEXT_PUBLIC_ENABLE_LOGS=true
NEXT_ANALYTICS_BACKEND_PROVIDER=postgres

# ---- Build settings ----
SKIP_ASSET_UPLOAD=1
SENTRY_IGNORE_API_RESOLUTION_ERROR=1
